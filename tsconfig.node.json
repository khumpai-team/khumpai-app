{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "types": ["node"],
    "isolatedModules": true,
    "composite": true,
    "outDir": "./node_modules/.tmp/tsconfig-node",
    "strict": true
  },
  "include": ["vite.config.ts", "src/agent/server/**/*.ts", "src/agent/foundryConfig.ts"]
}
