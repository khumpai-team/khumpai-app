DATABASE_URL=postgres://postgres:postgres@localhost:5433/khumpai

# Azure Application Insights — enables request tracing, latency, and error telemetry via OpenTelemetry.
# Optional: leave blank to disable observability (server runs fine without it).
APPLICATIONINSIGHTS_CONNECTION_STRING=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview
PORT=8787
ALLOWED_ORIGIN=http://localhost:5173

# Azure AI Content Safety — enables server-side input moderation (defense-in-depth layer).
# Optional: when either value is absent the module is a no-op and the deterministic
# client-side guardrails + Azure OpenAI built-in content filter remain active.
# Create a Content Safety resource in Azure Portal and copy the endpoint and key here.
CONTENT_SAFETY_ENDPOINT=
CONTENT_SAFETY_KEY=
