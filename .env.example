# Azure OpenAI (key auth) — read SERVER-SIDE only by the Vite dev-server proxy
# (src/agent/server/foundryProxyPlugin.ts via Vite loadEnv). The key never
# reaches the browser bundle. Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit your key.

# Resource endpoint, e.g. https://ais-team06-qmg6v3.cognitiveservices.azure.com/
AZURE_OPENAI_ENDPOINT=

# API key from the Azure portal -> your resource -> Keys and Endpoint
AZURE_OPENAI_API_KEY=

# The model deployment name, e.g. gpt-4.1
AZURE_OPENAI_DEPLOYMENT=

# API version (a sensible default is applied if omitted)
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Browser provider toggle: set to "foundry" to use Azure; anything else uses the mock.
VITE_AGENT_PROVIDER=
