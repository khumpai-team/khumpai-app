# =============================================================================
# Khumpai — environment variables example
# Copy this file to .env (gitignored) and fill in the values you need.
# =============================================================================

# ---------------------------------------------------------------------------
# Azure AI Foundry (Phase 2 — NOT required while MockAgentProvider is active)
#
# These variables are read by FoundryAgentProvider. They are completely ignored
# while the app uses MockAgentProvider (the default in src/agent/index.ts).
#
# AZURE_AI_PROJECT_CONNECTION_STRING
#   Found in Azure AI Foundry portal → your project → "Overview" tab →
#   "Project connection string". Format:
#   <region>.api.azureml.ms;<subscription-id>;<resource-group>;<project-name>
#
# AZURE_OPENAI_DEPLOYMENT
#   The name of the Azure OpenAI deployment to use (e.g. "gpt-4o").
#   Must be deployed in the same AI Foundry project.
# ---------------------------------------------------------------------------
AZURE_AI_PROJECT_CONNECTION_STRING=
AZURE_OPENAI_DEPLOYMENT=
